generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NOTE --> Sync === Zap (like Zapier does by letting us create a zap)

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  syncs    Sync[]
}

model Sync {
  id       String    @id @default(uuid())
  trigger  Trigger?
  actions  Action[]
  syncRuns SyncRun[]
  userId   String
  user     User      @relation(fields: [userId], references: [id])
}

model SyncRun {
  id            String         @id @default(uuid())
  syncId        String
  sync          Sync           @relation(fields: [syncId], references: [id])
  metadata      Json
  syncRunOutbox SyncRunOutbox?
}

model SyncRunOutbox {
  id        String  @id @default(uuid())
  syncRunId String  @unique
  syncRun   SyncRun @relation(fields: [syncRunId], references: [id])
}

model AvailableTrigger {
  id       String    @id @default(uuid())
  name     String
  image    String
  triggers Trigger[]
}

model Trigger {
  id                 String           @id @default(uuid())
  availableTriggerId String
  type               AvailableTrigger @relation(fields: [availableTriggerId], references: [id])
  syncId             String           @unique
  sync               Sync             @relation(fields: [syncId], references: [id])
  metadata           Json?
}

model AvailableAction {
  id      String   @id @default(uuid())
  name    String
  image   String
  actions Action[]
}

model Action {
  id                String          @id @default(uuid())
  availableActionId String
  type              AvailableAction @relation(fields: [availableActionId], references: [id])
  syncId            String
  sync              Sync            @relation(fields: [syncId], references: [id])
  sortingOrder      Int             @default(0)
  metadata          Json?
}
